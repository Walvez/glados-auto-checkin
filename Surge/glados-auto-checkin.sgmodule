#!name=GLaDOS 自动签到
#!desc=自动获取登录凭据，并在每天 07:15 和 15:15 执行 GLaDOS 签到。

[Script]
GLaDOS签到 = type=cron,cronexp="15 7,15 * * *",wake-system=1,timeout=20,script-path=https://raw.githubusercontent.com/Walvez/glados-auto-checkin/main/glados.autosign.surge.js
获取GLaDOS登录凭据 = type=http-request,pattern=^https:\/\/glados\.(network|rocks)\/,script-path=https://raw.githubusercontent.com/Walvez/glados-auto-checkin/main/glados.autosign.surge.js

[MITM]
hostname = %APPEND% glados.network, glados.rocks
