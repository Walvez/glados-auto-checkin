#!name=GLaDOS 自动签到
#!desc=自动获取登录凭据，每天 07:15 签到，15:15 仅在当天未成功时补签；使用 Surge 自带通知。

[Script]
GLaDOS签到 = type=cron,cronexp="15 7,15 * * *",wake-system=1,timeout=30,script-path=https://raw.githubusercontent.com/Walvez/glados-auto-checkin/refs/heads/main/glados.autosign.surge.js
获取GLaDOS登录凭据 = type=http-request,pattern=^https:\/\/glados\.(network|rocks|one|space|cloud|vip)\/,script-path=https://raw.githubusercontent.com/Walvez/glados-auto-checkin/refs/heads/main/glados.autosign.surge.js

[MITM]
hostname = %APPEND% glados.network, glados.rocks, glados.one, glados.space, glados.cloud, glados.vip
